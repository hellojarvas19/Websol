# ═══════════════════════════════════════════════════════════════════════════════
# HELIUS API KEYS (for fast wallet tracking)
# Get keys from https://www.helius.dev
#
# Supports MULTIPLE API keys for load balancing and higher throughput:
# - Each key has its own rate limit
# - Multiple keys allow tracking more wallets simultaneously
# - Keys are used in round-robin fashion automatically
#
# Format: HELIUS_API_KEY (main), HELIUS_API_KEY1, HELIUS_API_KEY2, etc.
# ═══════════════════════════════════════════════════════════════════════════════
HELIUS_API_KEY=
# HELIUS_API_KEY1=
# HELIUS_API_KEY2=
# HELIUS_API_KEY3=
# HELIUS_API_KEY4=
# HELIUS_API_KEY5=
# Add more as needed: HELIUS_API_KEY6, HELIUS_API_KEY7, ... up to HELIUS_API_KEY99

# Place in here as many RPC providers you want and separate them with a comma. e.g: https://rpc1.com,https://rpc2.com
# See https://www.quicknode.com or https://chainstack.com for free RPCs. The more connections here, the more wallets you can track
RPC_ENDPOINTS=https://api.mainnet-beta.solana.com

# Get this from Bot Father
BOT_TOKEN=

# Telegram User API (for posting BUY messages to groups) — from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# Your chat id to access admin commands
ADMIN_CHAT_ID=

# (optional)
# This is the url where your server is deployed, only use this when using webhook Telegram connection (in production)
# Make sure you dont have a "/" at the end or it will break!!
APP_URL=https://app-url.com

# change to "production" to use webhook and use "development" for polling (if set to production, APP_URL must be defined!)
ENVIRONMENT=development

# Database connection string
DATABASE_URL=

HANDICAT_WALLET_ADDRESS=your-wallet-address

# ═══════════════════════════════════════════════════════════════════════════════
# ENHANCED TOKEN ANALYSIS
# ═══════════════════════════════════════════════════════════════════════════════
# Set to "true" to enable comprehensive token analysis from multiple sources:
# - Birdeye: Market cap, liquidity, price (PRIMARY SOURCE)
# - Helius DAS: Full metadata, authorities, verified price
# - Moralis: DEX pairs, holders count, real-time price
# - GMGN: Trading signals, risk analysis, smart wallets
# - DexScreener: Real-time pairs, LP status, socials
# - Solana RPC: On-chain verification
# Note: This may slow down notifications slightly due to additional API calls
ENABLE_ENHANCED_METADATA=false

# ═══════════════════════════════════════════════════════════════════════════════
# BIRDEYE API (PRIMARY SOURCE for market cap & liquidity)
# Get your API key from https://birdeye.so
# Provides:
# - Real-time market cap
# - Total liquidity across all DEXs
# - Accurate price data
# - 24h volume and price changes
# ═══════════════════════════════════════════════════════════════════════════════
BIRDEYE_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# MORALIS API (fallback for DEX/holders/price data)
# Get your API key from https://moralis.io
# Free tier available - provides:
# - Token metadata (name, symbol, decimals)
# - Real-time price data
# - DEX pairs and liquidity info
# - Top holders data
# ═══════════════════════════════════════════════════════════════════════════════
MORALIS_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# SOLANA TRACKER API (recommended for accurate holders data)
# Get your API key from https://www.solanatracker.io
# 
# Provides from single endpoint (/tokens/{address}):
# - Total holders count
# - Top 10 holders percentage
# - Token risk score
# ═══════════════════════════════════════════════════════════════════════════════
SOLANA_TRACKER_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# BIRDEYE API (optional - for additional market data)
# Get your API key from https://birdeye.so
# Provides:
# - Additional price verification
# - Trading volume data
# - Holder count
# ═══════════════════════════════════════════════════════════════════════════════
BIRDEYE_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# GMGN API via APIFY (optional - most data available from other sources)
# The system works fully without this - it uses:
# - RugCheck API (free) for security verification
# - Jupiter API (free) for price data
# - All other configured sources
#
# Only configure if you want additional GMGN-specific data:
# - Smart wallet tracking
# - Dev's previous rug history
# - Hot level / trending indicators
#
# To use Apify:
# 1. Create account at https://apify.com
# 2. Create your own GMGN scraper actor
# 3. Get your API token from Apify Console
# ═══════════════════════════════════════════════════════════════════════════════
APIFY_API_TOKEN=
GMGN_APIFY_ACTOR_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# ADDITIONAL FREE APIs (no configuration needed - used automatically)
# ═══════════════════════════════════════════════════════════════════════════════
# These APIs are used automatically and require no API keys:
#
# RugCheck API (https://rugcheck.xyz)
# - Mint/freeze authority verification
# - Risk scoring and analysis
# - Security flags
#
# Jupiter Price API (https://jup.ag)
# - Real-time token prices
# - Fallback price source
#
# DexScreener API (https://dexscreener.com)
# - DEX pairs and liquidity
# - Volume and price changes
# - Social links
